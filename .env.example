# ============================================================
# Copia este archivo a .env.local y llena los valores reales
# ============================================================

# ── Google Gemini (IA Tutor) ─────────────────────────────
GEMINI_API_KEY=AIza...
# Modelos: gemini-2.0-flash (rápido/barato) | gemini-2.5-pro (mejor calidad)
MODELO=gemini-2.0-flash

# ── Clerk (Autenticación) ─────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
# Rutas de Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/tutor
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/configurar

# ── Supabase (Base de datos) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Mercado Pago (Pagos Colombia — MCO / COP) ─────────────
MELI_ACCESS_TOKEN=APP_USR-...
# Monto de prueba en COP (solo en desarrollo). En producción déjalo vacío.
# Ej: 2000 → cobra $2.000 COP en vez del precio real
MP_TEST_AMOUNT=2000

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_...
# Email desde el que envía (debe estar verificado en Resend)
# EMAIL_FROM=hola@tutordetareas.co

# ── Crons (Vercel) ────────────────────────────────────────
CRON_SECRET=un-secreto-largo-y-aleatorio

# ── Dev / Tests ───────────────────────────────────────────
# EMAIL_TEST_ALLOWLIST=tu@email.com,otro@email.com
